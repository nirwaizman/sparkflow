{
  "name": "@sparkflow/realtime-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Standalone Yjs websocket broker. Run alongside apps/web during local development and as its own process in production.",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "tsx src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@sparkflow/realtime": "workspace:*",
    "ws": "^8.18.0",
    "y-websocket": "^2.1",
    "yjs": "^13.6"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.0.0",
    "typescript": "5.8.2"
  }
}
