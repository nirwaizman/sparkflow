ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=

# Search providers
SEARCH_PROVIDER=demo
TAVILY_API_KEY=
SERPAPI_API_KEY=
FIRECRAWL_API_KEY=
JINA_API_KEY=
COHERE_API_KEY=

# Database (WP-A2)
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cache / rate limit (WP-A5)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Background jobs (WP-C4)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Observability (WP-A4)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
