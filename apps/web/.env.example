# Core
NEXT_PUBLIC_APP_NAME=SparkFlow

# LLM providers (set at least one; otherwise mock provider kicks in)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=

# Search providers
SEARCH_PROVIDER=demo
TAVILY_API_KEY=
SERPAPI_API_KEY=
FIRECRAWL_API_KEY=
JINA_API_KEY=
COHERE_API_KEY=

# Database (WP-A2)
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cache / rate limit (WP-A5)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Background jobs (WP-C4)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Observability (WP-A4)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Billing (WP-E1)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Transactional email (WP-E3)
RESEND_API_KEY=
RESEND_FROM_EMAIL=SparkFlow <noreply@yourdomain.com>

# Growth (WP-growth)
APP_REFERRAL_REWARD_CREDITS=100

# Code execution sandbox (WP-C2)
E2B_API_KEY=

# Google Drive + Gmail integrations (WP-integrations)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=http://localhost:3001/api/integrations/google/callback

# Browser automation (Browserbase — optional; falls back to local Playwright)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Phone calling (Vapi)
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_SECRET=

# AI Media — image / video / music providers (WP-media)
REPLICATE_API_TOKEN=
SUNO_API_KEY=
ELEVENLABS_API_KEY=

# Enterprise (WP-enterprise) — WorkOS SAML/OIDC + SCIM
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# Admin console (shared with apps/admin). HS256 signing key for
# impersonation JWTs + signed export URLs. Must be >= 32 chars. The web
# app reads this to verify `sf-impersonating` cookies minted by the
# admin console; apps/admin reads it to mint them.
ADMIN_IMPERSONATION_SECRET=
# Optional cookie domain shared between admin + web (e.g. `.sparkflow.app`)
# so the impersonation cookie is visible across subdomains. Leave blank
# for host-only cookies during local dev.
ADMIN_COOKIE_DOMAIN=
# Comma-separated list of admin emails allowed into apps/admin.
ADMIN_EMAILS=
