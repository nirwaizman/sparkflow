# Billing (WP-E1)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Transactional email (WP-E3)
RESEND_API_KEY=

# Code execution sandbox (WP-C2)
E2B_API_KEY=

# Google Drive + Gmail integrations (WP-integrations)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=http://localhost:3001/api/integrations/google/callback

# Browser automation (Browserbase — optional; falls back to local Playwright)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Phone calling (Vapi)
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_SECRET=

# AI Media — image / video / music providers (WP-media)
REPLICATE_API_TOKEN=
