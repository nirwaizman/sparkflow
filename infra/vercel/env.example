# =============================================================================
# SparkFlow — Production Vercel environment variables
# =============================================================================
# This file is an explicit checklist. Do NOT commit real values.
# Each variable is tagged with:
#   scope   — production | preview | development (comma-separated)
#   source  — where to copy the value from
#   secret  — yes/no (no = safe to expose to the browser, prefixed NEXT_PUBLIC_)
#
# Push into Vercel with infra/vercel/secrets.sh (reads this file).
# =============================================================================

# -----------------------------------------------------------------------------
# Public app URL (used by Supabase Auth redirect, OG, canonical URLs)
# scope=production,preview  source=your-domain  secret=no
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://app.sparkflow.io

# -----------------------------------------------------------------------------
# Supabase — production project
# Create the project in the Tokyo (ap-northeast-1) region.
# Supabase Dashboard → Project → Settings → API
# -----------------------------------------------------------------------------
# scope=production,preview,development  source=Supabase Settings → API → Project URL  secret=no
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# scope=production,preview,development  source=Supabase Settings → API → anon public  secret=no
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# scope=production  source=Supabase Settings → API → service_role  secret=yes
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# scope=production  source=Supabase Settings → Database → Connection string → URI (pooler, port 6543, pgbouncer=true)  secret=yes
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# scope=production  source=Supabase Settings → Database → Connection string → URI (direct, port 5432)  secret=yes
SUPABASE_DB_URL_DIRECT=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Stripe — live mode
# https://dashboard.stripe.com/apikeys (toggle VIEW LIVE DATA on)
# -----------------------------------------------------------------------------
# scope=production,preview  source=Stripe Dashboard → API keys → Publishable key (live)  secret=no
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# scope=production  source=Stripe Dashboard → API keys → Secret key (live)  secret=yes
STRIPE_SECRET_KEY=sk_live_...
# scope=production  source=Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret  secret=yes
STRIPE_WEBHOOK_SECRET=whsec_...
# scope=production  source=Stripe product price IDs (create in live mode)  secret=no
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...

# -----------------------------------------------------------------------------
# LLM providers
# -----------------------------------------------------------------------------
# scope=production  source=https://platform.openai.com/api-keys (prod-only key, usage limit set)  secret=yes
OPENAI_API_KEY=sk-proj-...
# scope=production  source=https://console.anthropic.com/settings/keys (prod-only key, rate-limited workspace)  secret=yes
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Email — Resend (also used as Supabase SMTP provider, see DEPLOY.md)
# -----------------------------------------------------------------------------
# scope=production  source=https://resend.com/api-keys  secret=yes
RESEND_API_KEY=re_...
# scope=production  source=verified domain in Resend  secret=no
RESEND_FROM_EMAIL=no-reply@mail.sparkflow.io

# -----------------------------------------------------------------------------
# Observability — Sentry (production DSN, separate from dev)
# -----------------------------------------------------------------------------
# scope=production,preview  source=Sentry → Project → Settings → Client Keys (DSN) — production project only  secret=no
NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# scope=production  source=Sentry → User Settings → Auth Tokens (scopes: project:releases, org:read)  secret=yes
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=sparkflow
SENTRY_PROJECT=sparkflow-web

# -----------------------------------------------------------------------------
# Product analytics — PostHog (use production project key)
# -----------------------------------------------------------------------------
# scope=production,preview  source=PostHog → Project Settings → Project API Key (prod project)  secret=no
NEXT_PUBLIC_POSTHOG_KEY=phc_...
# scope=production,preview  source=PostHog region  secret=no
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# -----------------------------------------------------------------------------
# Background jobs — Inngest
# -----------------------------------------------------------------------------
# scope=production  source=Inngest → Environment: Production → Event Keys  secret=yes
INNGEST_EVENT_KEY=...
# scope=production  source=Inngest → Environment: Production → Signing Key  secret=yes
INNGEST_SIGNING_KEY=signkey-prod-...

# -----------------------------------------------------------------------------
# OAuth providers (values live in Supabase Auth; duplicated here for CI parity)
# -----------------------------------------------------------------------------
# scope=production  source=Google Cloud Console → Credentials → OAuth 2.0 Client (Web)  secret=yes
GOOGLE_OAUTH_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
# scope=production  source=generated once via `openssl rand -hex 32`  secret=yes
CRON_SECRET=
NODE_ENV=production
